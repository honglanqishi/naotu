# =========================================
# Google OAuth（Google Cloud Console 获取）
# =========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =========================================
# better-auth 配置
# =========================================
# 随机 32 位字符串: openssl rand -hex 32
BETTER_AUTH_SECRET=your-32-char-random-secret-here

# BETTER_AUTH_URL = 后端真实对外可访问的 URL（用于生成 Google OAuth redirect_uri）
# ⚠️ 必须与 Google Cloud Console 中注册的 redirect_uri 域名一致
# ⚠️ 本地开发：http://localhost:3000（与前端同源，让 Next.js rewrite 代理到后端）
# ⚠️ 生产环境：https://your-domain.com（经 Nginx 统一对外）
BETTER_AUTH_URL=https://your-domain.com
# 本地开发用:
# BETTER_AUTH_URL=http://localhost:3000

# =========================================
# 鉴权开关（AUTH_ENABLED=false 可一键关闭登录）
# 关闭后后端使用固定游客账号，前端跳过 session 检查
# 生产环境请设为 true 或省略此行（默认 true）
# =========================================
AUTH_ENABLED=true
# 前端对应变量（Next.js 客户端可读）
# 写入 frontend/.env.local:  NEXT_PUBLIC_AUTH_ENABLED=true

# =========================================
# 数据库
# =========================================
# 生产环境（PostgreSQL）：
DATABASE_URL=postgresql://naotu:naotu_password@postgres:5432/naotu_db
# 本地 Docker 调试用：
# DATABASE_URL=postgresql://naotu:naotu_password@localhost:5432/naotu_db

# 本地开发（SQLite）：
# NODE_ENV=development 时自动使用 SQLite，以下变量可选
# SQLITE_PATH=../local.db   # 相对于 backend/ 目录，默认 ../local.db

# =========================================
# 前端
# =========================================
# NEXT_PUBLIC_API_URL：浏览器端 better-auth client 连接的地址
# 生产：https://your-domain.com（经 Nginx 路由，同源，无跨域问题）
# 本地：留空（让 auth-client 走相对路径，由 Next.js rewrite 代理到后端）
NEXT_PUBLIC_API_URL=https://your-domain.com
# 本地开发用（留空，不要填 localhost:3001 否则跨域导致 cookie 失效 → invalid_code）:
# NEXT_PUBLIC_API_URL=

# FRONTEND_URL：后端 CORS 白名单 & better-auth trustedOrigins
# 生产：https://your-domain.com
# 本地：http://localhost:3000
FRONTEND_URL=https://your-domain.com
# 本地开发用:
# FRONTEND_URL=http://localhost:3000

# BACKEND_INTERNAL_URL：仅服务端使用（Next.js rewrite 的目标地址）
# 生产 Docker 内网: http://backend:3001
# 本地开发: http://localhost:3001
BACKEND_INTERNAL_URL=http://backend:3001
# 本地开发用:
# BACKEND_INTERNAL_URL=http://localhost:3001

# =========================================
# 端口（可选，有默认值）
# =========================================
BACKEND_PORT=3001
FRONTEND_PORT=3000

# =========================================
# 本地代理（仅本地开发需要，用于解决国内无法访问 Google OAuth 的问题）
# Node.js fetch/undici 默认不走系统代理，需要显式配置
# 填写你本地代理软件的 HTTP 端口（Clash 默认 7890，v2ray 常见 10809）
# =========================================
# HTTPS_PROXY=http://127.0.0.1:7890

{
    "name": "naotu",
    "version": "1.0.0",
    "description": "Naotu workspace",
    "private": true,
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "install:all": "pnpm install -r",
        "predev": "node -e \"const {execSync}=require('child_process');['3001','3000'].forEach(p=>{try{const r=execSync(`netstat -ano`).toString();const lines=r.split('\\n').filter(l=>l.includes(':'+p) && l.includes('LISTENING'));lines.forEach(l=>{const pid=l.trim().split(/\\s+/).pop();if(pid&&pid!=='0')try{execSync('taskkill /F /PID '+pid,{stdio:'ignore'})}catch(e){}});}catch(e){}});console.log('Ports cleared')\"",
        "predev:desktop": "node -e \"const {execSync}=require('child_process');['3001','3000'].forEach(p=>{try{const r=execSync(`netstat -ano`).toString();const lines=r.split('\\n').filter(l=>l.includes(':'+p) && l.includes('LISTENING'));lines.forEach(l=>{const pid=l.trim().split(/\\s+/).pop();if(pid&&pid!=='0')try{execSync('taskkill /F /PID '+pid,{stdio:'ignore'})}catch(e){}});}catch(e){}});console.log('Ports cleared')\"",
        "dev": "pnpm migrate:local && concurrently --names \"backend,frontend\" --prefix-colors \"blue,green\" \"pnpm dev:backend\" \"pnpm dev:frontend\"",
        "dev:backend": "pnpm --dir backend dev",
        "dev:frontend": "pnpm --dir frontend dev",
        "dev:desktop": "pnpm migrate:local && pnpm --dir electron dev",
        "build:electron": "pnpm --dir backend build && pnpm --dir frontend build && pnpm --dir electron build",
        "pack:desktop": "pnpm build:electron && pnpm --dir electron pack",
        "dist:desktop": "pnpm build:electron && pnpm --dir electron dist",
        "migrate:local": "pnpm --dir database generate:local && pnpm --dir database migrate:local",
        "migrate": "pnpm --dir database migrate",
        "dev:pg": "concurrently --names \"postgres,backend,frontend\" --prefix-colors \"yellow,blue,green\" \"docker-compose up postgres\" \"pnpm dev:backend\" \"pnpm dev:frontend\""
    },
    "devDependencies": {
        "concurrently": "^9.0.0"
    }
}